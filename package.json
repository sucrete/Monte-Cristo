    "lexical": "^0.44.0",
    "moment": "^2.30.1",
    "next": "16.2.4",
    "next-sanity": "^12.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
