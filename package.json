{
  "name": "monte-cristo",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "postinstall": "tsx folder-rename.ts --utb",
    "dev": "concurrently \"next dev --turbopack --port 3012\" \"npm run editor-css:watch\"",
    "build": "npm run editor-css && next build",
    "editor-css": "postcss src/styles/editor.entry.css -o public/editor.css ",
    "editor-css:watch": "postcss src/styles/editor.entry.css -o public/editor.css  --watch",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
